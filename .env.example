# ── Stripe keys (เอามาจาก Stripe Dashboard → Developers → API keys) ──
# ⚠️ ห้าม commit ไฟล์นี้ขึ้น git — ใส่ค่าจริงในไฟล์ .env เท่านั้น
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxx

# Webhook signing secret (จาก Stripe Dashboard → Developers → Webhooks → เลือก endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxx

# ── ความลับสำหรับเซ็น JWT (สุ่มยาว ๆ เช่น: openssl rand -hex 32) ──
JWT_SECRET=เปลี่ยนเป็นค่าสุ่มยาวก่อนขึ้น-production

# ── อีเมล (ลืมรหัสผ่าน — ส่งรหัสยืนยัน 6 หลักเข้าอีเมลที่สมัคร) ──
# ⚠️ ต้องตั้งก่อนเปิดจริง — ถ้าไม่ตั้ง รหัสจะถูกพิมพ์ออก console ของเซิร์ฟเวอร์เท่านั้น (ลูกค้าไม่ได้รับ)
# ผู้ให้บริการที่ตั้งง่าย: Resend / Brevo / Mailgun / Gmail SMTP (App Password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=BoostHub <no-reply@boosthub.local>

# ── เข้าสู่ระบบด้วย Google (Gmail) ──
# สร้าง OAuth Client ID ที่ console.cloud.google.com → APIs & Services → Credentials
# ชนิด Web application → ใส่โดเมนหน้าเว็บใน Authorized JavaScript origins
# ตั้งค่านี้แล้วปุ่ม "Continue with Google" จะโผล่ในหน้าล็อกอินอัตโนมัติ
GOOGLE_CLIENT_ID=

# URL หน้าเว็บลูกค้า
FRONTEND_URL=http://localhost:3000

# ── บัญชีแอดมินตัวแรก (ใช้ตอนรัน npm run seed) ──
ADMIN_EMAIL=admin@boosthub.local
ADMIN_PASSWORD=admin1234

# ที่เก็บไฟล์ฐานข้อมูล SQLite (ไม่ตั้งก็ได้ → boosthub.db)
# ⚠️ บน Render: ต้องตั้งเป็นพาธบน Persistent Disk เช่น /data/boosthub.db
#    ไม่งั้นข้อมูลหายทุกครั้งที่ deploy/restart (ดู render.yaml ที่ราก repo)
DB_PATH=./boosthub.db

# พอร์ตของเซิร์ฟเวอร์
PORT=4242

# โดเมนหน้าเว็บ (สำหรับ CORS) ใส่หลายโดเมนได้ คั่นด้วย comma
# เช่น https://boosthub.com,https://www.boosthub.com
# ⚠️ ตอนเปิดจริงห้ามใช้ * — ตั้งเป็นโดเมนเว็บจริงเท่านั้น
FRONTEND_ORIGIN=*
